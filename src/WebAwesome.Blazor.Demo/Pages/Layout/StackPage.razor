@page "/layout/stack"

<PageTitle>Stack</PageTitle>

<h1>Stack</h1>
<p>The Stack layout arranges elements in the block direction with even spacing, and is well suited for forms, text, and ensuring consistent spacing between elements in the document flow. <code>WaStack</code> renders a <code>div</code> with the <code>wa-stack</code> utility class.</p>

<ExampleSection Title="Default" Code="@DefaultExample">
    <WaStack>
        <div style="background: var(--wa-color-surface-lowered, #eee); padding: 1rem;">Box 1</div>
        <div style="background: var(--wa-color-surface-lowered, #eee); padding: 1rem;">Box 2</div>
        <div style="background: var(--wa-color-surface-lowered, #eee); padding: 1rem;">Box 3</div>
    </WaStack>
</ExampleSection>

<ExampleSection Title="Gap" Code="@GapExample">
    <WaStack Gap="GapSize.Gap_2XS">
        <div style="background: var(--wa-color-surface-lowered, #eee); padding: 1rem;">Box 1</div>
        <div style="background: var(--wa-color-surface-lowered, #eee); padding: 1rem;">Box 2</div>
        <div style="background: var(--wa-color-surface-lowered, #eee); padding: 1rem;">Box 3</div>
    </WaStack>
</ExampleSection>

<ExampleSection Title="A Simple Form" Code="@FormExample">
    <WaStack>
        <WaInput Label="Email" @bind-Value="email" />
        <WaInput Label="Password" Type="WaInputType.Password" @bind-Value="password" />
        <WaCheckbox @bind-Value="remember">Remember me on this device</WaCheckbox>
        <WaButton>Log In</WaButton>
    </WaStack>
</ExampleSection>

@code {
    private string? email;
    private string? password;
    private bool remember;

    private const string DefaultExample = """
        <WaStack>
            <div style="background: var(--wa-color-surface-lowered, #eee); padding: 1rem;">Box 1</div>
            <div style="background: var(--wa-color-surface-lowered, #eee); padding: 1rem;">Box 2</div>
            <div style="background: var(--wa-color-surface-lowered, #eee); padding: 1rem;">Box 3</div>
        </WaStack>
        """;

    private const string GapExample = """
        <WaStack Gap="GapSize.Gap_2XS">
            <div style="background: var(--wa-color-surface-lowered, #eee); padding: 1rem;">Box 1</div>
            <div style="background: var(--wa-color-surface-lowered, #eee); padding: 1rem;">Box 2</div>
            <div style="background: var(--wa-color-surface-lowered, #eee); padding: 1rem;">Box 3</div>
        </WaStack>
        """;

    private const string FormExample = """
        <WaStack>
            <WaInput Label="Email" @bind-Value="email" />
            <WaInput Label="Password" Type="WaInputType.Password" @bind-Value="password" />
            <WaCheckbox @bind-Value="remember">Remember me on this device</WaCheckbox>
            <WaButton>Log In</WaButton>
        </WaStack>
        """;
}
