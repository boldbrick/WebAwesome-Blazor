@page "/showcases/media-gallery"

<PageTitle>Showcase: Media Gallery</PageTitle>

<h1>Nova Studio — Media Gallery</h1>
<p>
    The asset review screen of Nova Studio: a carousel of renders, a before/after comparison,
    a zoomable embedded preview, an animated sticker, a QR code for mobile review and a
    scrollable strip of gallery thumbnails.
</p>

<WaGrid MinColumnSize="22rem" Gap="GapSize.Gap_L">
    <WaCard WithHeader="true">
        <HeaderContent>
            <WaCluster Gap="GapSize.Gap_XS" AlignItems="AlignItems.Center">
                <WaText Variant="TextVariant.Heading" Element="h2">Launch renders</WaText>
                <WaBadge Variant="WaVariant.Brand" Pill="true">slide @(currentSlide + 1) / 3</WaBadge>
            </WaCluster>
        </HeaderContent>
        <ChildContent>
            <WaCarousel Pagination="true" Navigation="true" Loop="true" MouseDragging="true"
                        OnSlideChange="@(e => currentSlide = e.Index)">
                <WaCarouselItem>
                    <div style="height: 220px; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, #4a7dff, #7c3aed); color: white;">
                        <WaText Variant="TextVariant.Heading" Size="TextSize.XL">Hero banner — dawn</WaText>
                    </div>
                </WaCarouselItem>
                <WaCarouselItem>
                    <div style="height: 220px; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, #16a34a, #0ea5e9); color: white;">
                        <WaText Variant="TextVariant.Heading" Size="TextSize.XL">Feature spotlight — collaboration</WaText>
                    </div>
                </WaCarouselItem>
                <WaCarouselItem>
                    <div style="height: 220px; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, #d97706, #dc2626); color: white;">
                        <WaText Variant="TextVariant.Heading" Size="TextSize.XL">Pricing page — sunset</WaText>
                    </div>
                </WaCarouselItem>
            </WaCarousel>
        </ChildContent>
    </WaCard>

    <WaCard WithHeader="true">
        <HeaderContent>
            <WaText Variant="TextVariant.Heading" Element="h2">Redesign comparison</WaText>
        </HeaderContent>
        <ChildContent>
            <p>Drag the handle to compare the old and new editor toolbar.</p>
            <WaComparison Position="40">
                <BeforeContent>
                    <div style="height: 200px; display: flex; align-items: center; justify-content: center; background: var(--wa-color-neutral-fill-normal);">
                        <WaText Variant="TextVariant.Heading">Toolbar v2 (current)</WaText>
                    </div>
                </BeforeContent>
                <AfterContent>
                    <div style="height: 200px; display: flex; align-items: center; justify-content: center; background: var(--wa-color-brand-fill-loud); color: var(--wa-color-brand-on-loud);">
                        <WaText Variant="TextVariant.Heading">Toolbar v3 (proposal)</WaText>
                    </div>
                </AfterContent>
            </WaComparison>
        </ChildContent>
    </WaCard>

    <WaCard WithHeader="true">
        <HeaderContent>
            <WaText Variant="TextVariant.Heading" Element="h2">Zoomable spec preview</WaText>
        </HeaderContent>
        <ChildContent>
            <p>The embedded style-guide excerpt can be zoomed and panned without leaving the review.</p>
            <WaZoomableFrame Style="height: 220px;" Zoom="0.8"
                             SrcDoc="@("<body style='font-family: sans-serif; padding: 2rem;'><h1 style='color:#4a7dff;'>Nova brand sheet</h1><p>Primary: #4a7dff &middot; Success: #16a34a &middot; Warning: #d97706</p><p>Headings use Inter; body text uses the platform UI font.</p></body>")" />
        </ChildContent>
    </WaCard>

    <WaCard WithHeader="true">
        <HeaderContent>
            <WaText Variant="TextVariant.Heading" Element="h2">Stickers &amp; motion</WaText>
        </HeaderContent>
        <ChildContent>
            <WaCluster Gap="GapSize.Gap_L" AlignItems="AlignItems.Center">
                <WaAnimatedImage Src="https://shoelace.style/assets/images/walk.gif" Alt="Animated walking sticker"
                                 Style="width: 120px; height: 120px;" />
                <WaAnimation Name="pulse" Play="true" Iterations="1000" Duration="2000">
                    <WaIcon Name="heart" Variant="solid" Style="font-size: 3rem; color: var(--wa-color-danger-fill-loud);" Label="Liked" />
                </WaAnimation>
                <div style="text-align: center;">
                    <WaQrCode Value="https://demo.meridianlabs.example/gallery/nova-3-2" Label="Open this gallery on your phone" Size="120" Radius="0.3m" />
                    <WaText Variant="TextVariant.Caption" Element="div">Review on mobile</WaText>
                </div>
            </WaCluster>
        </ChildContent>
    </WaCard>
</WaGrid>

<WaCard WithHeader="true" Style="margin-block-start: var(--wa-space-l);">
    <HeaderContent>
        <WaText Variant="TextVariant.Heading" Element="h2">All gallery assets</WaText>
    </HeaderContent>
    <ChildContent>
        <WaScroller Orientation="WaOrientation.Horizontal">
            <WaCluster Gap="GapSize.Gap_M" Style="flex-wrap: nowrap; padding-block: var(--wa-space-xs);">
                @foreach (var asset in assets)
                {
                    <figure style="margin: 0; width: 11rem; flex: none;">
                        <WaFrame AspectRatio="@asset.Ratio">
                            <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: @asset.Background;">
                                <WaIcon Name="@asset.IconName" Variant="solid" Style="font-size: 2rem; color: white;" Label="@asset.Name" />
                            </div>
                        </WaFrame>
                        <figcaption>
                            <WaCluster Gap="GapSize.Gap_2XS" AlignItems="AlignItems.Center">
                                <WaAvatar Initials="@asset.OwnerInitials" Label="@asset.Owner" Style="--size: 1.5rem;" />
                                <WaText Variant="TextVariant.Caption">@asset.Name</WaText>
                                <WaTag Size="WaSize.Small" Pill="true">@asset.Kind</WaTag>
                            </WaCluster>
                        </figcaption>
                    </figure>
                }
            </WaCluster>
        </WaScroller>
    </ChildContent>
</WaCard>

@code {
    private int currentSlide;

    private sealed record GalleryAsset(string Name, string Kind, string IconName, string Background, FrameAspectRatio Ratio, string Owner, string OwnerInitials);

    private readonly GalleryAsset[] assets =
    [
        new("Hero dawn", "render", "image", "linear-gradient(135deg, #4a7dff, #7c3aed)", FrameAspectRatio.Landscape, "Mara Lindqvist", "ML"),
        new("Logo motion", "video", "film", "linear-gradient(135deg, #dc2626, #d97706)", FrameAspectRatio.Square, "Jonas Petrov", "JP"),
        new("App icon set", "icons", "shapes", "linear-gradient(135deg, #16a34a, #0ea5e9)", FrameAspectRatio.Square, "Priya Anand", "PA"),
        new("Poster A2", "print", "file-image", "linear-gradient(135deg, #7c3aed, #db2777)", FrameAspectRatio.Portrait, "Tomás Ruiz", "TR"),
        new("Social teaser", "video", "clapperboard", "linear-gradient(135deg, #0ea5e9, #4a7dff)", FrameAspectRatio.Landscape, "Mara Lindqvist", "ML"),
        new("Sticker pack", "stickers", "note-sticky", "linear-gradient(135deg, #d97706, #16a34a)", FrameAspectRatio.Square, "Jonas Petrov", "JP")
    ];
}
