@page "/components/intersection-observer"

<PageTitle>Intersection Observer</PageTitle>

<h1>Intersection Observer</h1>
<p><code>&lt;wa-intersection-observer&gt;</code> wrapped by <code>WaIntersectionObserver</code>.</p>

<ExampleSection Title="Default" Code="@DefaultExample">
    <WaIntersectionObserver Threshold="1" OnIntersect="HandleIntersect">
        <div style="border: solid 2px var(--wa-color-surface-border); padding: 4rem 2rem; text-align: center;">
            Scroll and watch the message below.
        </div>
    </WaIntersectionObserver>
    <p>@intersectMessage</p>
</ExampleSection>

