@page "/components/input"

<PageTitle>Input</PageTitle>

<h1>Input</h1>
<p>Inputs collect single-line text data from the user. <code>&lt;wa-input&gt;</code> wrapped by <code>WaInput</code>.</p>

<ExampleSection Title="Default" Code="@DefaultExample">
    <WaInput @bind-Value="defaultValue" />
</ExampleSection>

<ExampleSection Title="Label &amp; Hint" Code="@LabelHintExample">
    <WaInput Label="Nickname" Hint="What would you like people to call you?" @bind-Value="nickname" />
</ExampleSection>

<ExampleSection Title="Placeholder, Clearable &amp; Password Toggle" Code="@PlaceholderExample">
    <WaInput Placeholder="Clearable" WithClear="true" @bind-Value="clearableValue" />
    <WaInput Type="WaInputType.Password" Placeholder="Password Toggle" PasswordToggle="true" @bind-Value="passwordValue" />
</ExampleSection>

<ExampleSection Title="Appearance, Pill &amp; Disabled" Code="@AppearanceExample">
    <WaInput Placeholder="Filled" Appearance="WaInputAppearance.Filled" @bind-Value="filledValue" />
    <WaInput Placeholder="Pill" Pill="true" @bind-Value="pillValue" />
    <WaInput Placeholder="Disabled" Disabled="true" @bind-Value="disabledValue" />
</ExampleSection>

<ExampleSection Title="Sizes" Code="@SizesExample">
    <WaInput Placeholder="Small" Size="WaSize.Small" @bind-Value="smallValue" />
    <WaInput Placeholder="Medium" Size="WaSize.Medium" @bind-Value="mediumValue" />
    <WaInput Placeholder="Large" Size="WaSize.Large" @bind-Value="largeValue" />
</ExampleSection>

<ExampleSection Title="Start &amp; End Decorations" Code="@DecorationsExample">
    <WaInput Placeholder="Search" StartIconName="magnifying-glass" EndIconName="circle-xmark" @bind-Value="searchValue" />
</ExampleSection>

<ExampleSection Title="Two-way Binding" Code="@BindingExample">
    <WaInput Label="Type something" @bind-Value="name" />
    <p>You typed: <strong>@name</strong></p>
</ExampleSection>

<ApiTable Tag="wa-input" />

@code {
    private string? name;
    private string? defaultValue;
    private string? nickname;
    private string? clearableValue;
    private string? passwordValue;
    private string? filledValue;
    private string? pillValue;
    private string? disabledValue;
    private string? smallValue;
    private string? mediumValue;
    private string? largeValue;
    private string? searchValue;

    private const string DefaultExample = """
        <WaInput @bind-Value="defaultValue" />

        @code {
            private string? defaultValue;
        }
        """;

    private const string LabelHintExample = """
        <WaInput Label="Nickname" Hint="What would you like people to call you?" @bind-Value="nickname" />

        @code {
            private string? nickname;
        }
        """;

    private const string PlaceholderExample = """
        <WaInput Placeholder="Clearable" WithClear="true" @bind-Value="clearableValue" />
        <WaInput Type="WaInputType.Password" Placeholder="Password Toggle" PasswordToggle="true" @bind-Value="passwordValue" />

        @code {
            private string? clearableValue;
            private string? passwordValue;
        }
        """;

    private const string AppearanceExample = """
        <WaInput Placeholder="Filled" Appearance="WaInputAppearance.Filled" @bind-Value="filledValue" />
        <WaInput Placeholder="Pill" Pill="true" @bind-Value="pillValue" />
        <WaInput Placeholder="Disabled" Disabled="true" @bind-Value="disabledValue" />

        @code {
            private string? filledValue;
            private string? pillValue;
            private string? disabledValue;
        }
        """;

    private const string SizesExample = """
        <WaInput Placeholder="Small" Size="WaSize.Small" @bind-Value="smallValue" />
        <WaInput Placeholder="Medium" Size="WaSize.Medium" @bind-Value="mediumValue" />
        <WaInput Placeholder="Large" Size="WaSize.Large" @bind-Value="largeValue" />

        @code {
            private string? smallValue;
            private string? mediumValue;
            private string? largeValue;
        }
        """;

    private const string DecorationsExample = """
        <WaInput Placeholder="Search" StartIconName="magnifying-glass" EndIconName="circle-xmark" @bind-Value="searchValue" />

        @code {
            private string? searchValue;
        }
        """;

    private const string BindingExample = """
        <WaInput Label="Type something" @bind-Value="name" />
        <p>You typed: @name</p>

        @code {
            private string? name;
        }
        """;
}
