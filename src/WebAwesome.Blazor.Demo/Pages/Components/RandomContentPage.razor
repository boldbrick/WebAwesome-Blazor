        </WaRandomContent>
        """;

    private const string LayoutExample = """
        @* The host is display:contents by default; give it its own display to lay several items out *@
        <WaRandomContent @ref="layoutDemo" Items="3" Style="display: flex; gap: var(--wa-space-m); flex-wrap: wrap">
            <WaAvatar Label="Jordan Hayes" Initials="JH" />
            <WaAvatar Label="Mara Goldberg" Initials="MG" />
