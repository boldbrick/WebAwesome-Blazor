        <WaRandomContent Mode="WaRandomContentMode.Unique" Animation="WaRandomContentAnimation.FadeUp"
                         Autoplay="true" AutoplayInterval="3000">
            <div><WaIcon Name="octopus" /> Octopuses have three hearts.</div>
            <div><WaIcon Name="bee" /> Honey never spoils.</div>
            <div><WaIcon Name="feather" /> A group of flamingos is called a flamboyance.</div>
