        """;

    private const string ModeExample = """
        @* Mode: Unique (default) never repeats; Random may repeat; Sequence steps in DOM order *@
        <WaRandomContent @ref="modeDemo" Mode="WaRandomContentMode.Sequence">
            <WaTag Variant="WaVariant.Brand">A</WaTag>
            <WaTag Variant="WaVariant.Success">B</WaTag>
