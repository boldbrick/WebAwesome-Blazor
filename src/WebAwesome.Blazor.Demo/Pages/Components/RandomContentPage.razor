            <p>Good morning!</p>
            <p>Welcome back.</p>
            <p>What are you building today?</p>
        </WaRandomContent>
        <WaDivider />
        <WaButton Appearance="WaAppearance.Filled" OnClick="@(() => animationDemo!.RandomizeAsync())">Next</WaButton>
        """;

    private const string AutoplayExample = """
        @* Rotates on a timer; pauses on hover/focus and respects reduced motion.
