            </WaCallout>
        </WaRandomContent>
        <WaDivider />
        <WaButton Appearance="WaAppearance.Filled" OnClick="@(() => overview!.RandomizeAsync())">Shuffle</WaButton>

        @code {
            private WaRandomContent? overview;
        }
        """;

    private const string ProvidingExample = """
        <WaRandomContent @ref="providing">
            <p>Plain text works fine.</p>
            <WaBadge Variant="WaVariant.Brand">So do components</WaBadge>
