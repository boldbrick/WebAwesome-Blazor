    private bool defaultOpen;
    private bool noHeaderOpen;
    private bool startOpen;
    private bool topOpen;
    private bool actionsOpen;
    private bool dismissOpen;

    private const string DefaultExample = """
        <WaButton OnClick="@(() => open = true)">Open Drawer</WaButton>
        <WaDrawer Label="Drawer" Open="open" OnHide="@(() => open = false)">
