@page "/components/button"
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>Button</PageTitle>

<h1>Button</h1>
<p>Buttons represent actions that are available to the user. <code>&lt;wa-button&gt;</code> wrapped by <code>WaButton</code>.</p>

<ExampleSection Title="Default" Code="@DefaultExample">
    <WaButton />
</ExampleSection>

<ExampleSection Title="Variants" Code="@VariantsExample">
    <WaButton Variant="WaVariant.Neutral">Neutral</WaButton>
    <WaButton Variant="WaVariant.Brand">Brand</WaButton>
    <WaButton Variant="WaVariant.Success">Success</WaButton>
    <WaButton Variant="WaVariant.Warning">Warning</WaButton>
    <WaButton Variant="WaVariant.Danger">Danger</WaButton>
</ExampleSection>

<ExampleSection Title="Appearance" Code="@AppearanceExample">
    <WaButton Appearance="WaAppearance.Accent" Variant="WaVariant.Brand">Accent</WaButton>
    <WaButton Appearance="WaAppearance.Filled" Variant="WaVariant.Brand">Filled</WaButton>
    <WaButton Appearance="WaAppearance.Outlined" Variant="WaVariant.Brand">Outlined</WaButton>
    <WaButton Appearance="WaAppearance.Plain" Variant="WaVariant.Brand">Plain</WaButton>
</ExampleSection>

<ExampleSection Title="Sizes" Code="@SizesExample">
    <WaButton Size="WaSize.Small">Small</WaButton>
    <WaButton Size="WaSize.Medium">Medium</WaButton>
    <WaButton Size="WaSize.Large">Large</WaButton>
</ExampleSection>

<ExampleSection Title="Pill Buttons" Code="@PillExample">
    <WaButton Size="WaSize.Small" Pill="true">Small</WaButton>
    <WaButton Size="WaSize.Medium" Pill="true">Medium</WaButton>
    <WaButton Size="WaSize.Large" Pill="true">Large</WaButton>
</ExampleSection>

<ExampleSection Title="Start &amp; End Decorations" Code="@DecorationsExample">
    <WaButton Size="WaSize.Small" StartIconName="gear">Settings</WaButton>
    <WaButton Size="WaSize.Small" EndIconName="undo">Refresh</WaButton>
</ExampleSection>

<ExampleSection Title="Loading &amp; Disabled" Code="@LoadingDisabledExample">
    <WaButton Variant="WaVariant.Brand" Loading="true">Brand</WaButton>
    <WaButton Variant="WaVariant.Success" Disabled="true">Success</WaButton>
</ExampleSection>

<ExampleSection Title="External Submit via Form Association" Code="@ExternalSubmitExample">
    <p>
        A submit button placed <em>outside</em> a form can drive it through the native <code>form="id"</code>
        association — Web Awesome form controls and buttons are form-associated custom elements. This composes
        with Blazor's <code>EditForm</code>: the external button triggers the form's submit event, which
        <code>EditForm</code> intercepts as usual.
    </p>
    <EditForm id="external-submit-form" EditContext="externalFormContext" OnSubmit="OnExternalSubmit">
        <WaInput Label="Display name" Placeholder="Type anything" @bind-Value="externalFormModel.DisplayName" />
    </EditForm>
    <div style="margin-top: var(--wa-space-m);">
        <WaButton Variant="WaVariant.Brand" Type="WaButtonType.Submit" Form="external-submit-form" data-testid="external-submit">
            Submit from outside the form
        </WaButton>
    </div>
    @if (externalSubmitCount > 0)
    {
        <WaCallout Variant="WaVariant.Success" data-testid="external-submit-result" Style="margin-top: var(--wa-space-m);">
            Submitted @externalSubmitCount time(s) — last value: @(string.IsNullOrEmpty(lastSubmittedName) ? "(empty)" : lastSubmittedName)
        </WaCallout>
    }
</ExampleSection>

<ApiTable Tag="wa-button" />

@code {
    private ExternalFormModel externalFormModel = new();
    private EditContext externalFormContext = null!;
    private int externalSubmitCount;
    private string? lastSubmittedName;

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        externalFormContext = new EditContext(externalFormModel);
    }

    private void OnExternalSubmit()
    {
        externalSubmitCount++;
        lastSubmittedName = externalFormModel.DisplayName;
    }

    private class ExternalFormModel
    {
        public string? DisplayName { get; set; }
    }

    private const string DefaultExample = "<WaButton />";

    private const string ExternalSubmitExample = """
        <EditForm id="external-submit-form" EditContext="externalFormContext" OnSubmit="OnExternalSubmit">
            <WaInput Label="Display name" @bind-Value="externalFormModel.DisplayName" />
        </EditForm>
        <WaButton Type="WaButtonType.Submit" Form="external-submit-form">
            Submit from outside the form
        </WaButton>

        @code {
            private ExternalFormModel externalFormModel = new();
            private EditContext externalFormContext = null!;

            protected override void OnInitialized()
            {
                externalFormContext = new EditContext(externalFormModel);
            }

            private void OnExternalSubmit() { /* runs on external-button submit */ }
        }
        """;

    private const string VariantsExample = """
        <WaButton Variant="WaVariant.Neutral">Neutral</WaButton>
        <WaButton Variant="WaVariant.Brand">Brand</WaButton>
        <WaButton Variant="WaVariant.Success">Success</WaButton>
        <WaButton Variant="WaVariant.Warning">Warning</WaButton>
        <WaButton Variant="WaVariant.Danger">Danger</WaButton>
        """;

    private const string AppearanceExample = """
        <WaButton Appearance="WaAppearance.Accent" Variant="WaVariant.Brand">Accent</WaButton>
        <WaButton Appearance="WaAppearance.Filled" Variant="WaVariant.Brand">Filled</WaButton>
        <WaButton Appearance="WaAppearance.Outlined" Variant="WaVariant.Brand">Outlined</WaButton>
        <WaButton Appearance="WaAppearance.Plain" Variant="WaVariant.Brand">Plain</WaButton>
        """;

    private const string SizesExample = """
        <WaButton Size="WaSize.Small">Small</WaButton>
        <WaButton Size="WaSize.Medium">Medium</WaButton>
        <WaButton Size="WaSize.Large">Large</WaButton>
        """;

    private const string PillExample = """
        <WaButton Size="WaSize.Small" Pill="true">Small</WaButton>
        <WaButton Size="WaSize.Medium" Pill="true">Medium</WaButton>
        <WaButton Size="WaSize.Large" Pill="true">Large</WaButton>
        """;

    private const string DecorationsExample = """
        <WaButton Size="WaSize.Small" StartIconName="gear">Settings</WaButton>
        <WaButton Size="WaSize.Small" EndIconName="undo">Refresh</WaButton>
        """;

    private const string LoadingDisabledExample = """
        <WaButton Variant="WaVariant.Brand" Loading="true">Brand</WaButton>
        <WaButton Variant="WaVariant.Success" Disabled="true">Success</WaButton>
        """;
}
