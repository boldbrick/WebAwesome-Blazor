@inherits LayoutComponentBase
@inject ApiSurfaceService SurfaceService
@inject IJSRuntime JS
@inject WebAwesome.Blazor.Models.WebAwesomeOptions WaOptions

<div class="demo-shell">
    <aside class="demo-sidebar">
        <a class="demo-logo" href="">Web Awesome <strong>Blazor</strong></a>

        <div class="demo-controls">
            <WaSelect Label="Theme" @bind-Value="theme" @bind-Value:after="ApplyThemeAsync">
                <WaOption Value="default">Default</WaOption>
                <WaOption Value="awesome">Awesome</WaOption>
                <WaOption Value="shoelace">Shoelace</WaOption>
            </WaSelect>
            <WaSwitch @bind-Value="dark" @bind-Value:after="ApplyDarkAsync">Dark mode</WaSwitch>
        </div>

        <nav>
            <h4>Getting Started</h4>
            <ul>
                <li><NavLink href="" Match="NavLinkMatch.All">Introduction</NavLink></li>
            </ul>

            <h4>Components</h4>
            <ul>
                @foreach (var (tag, component) in componentLinks)
                {
                    <li><NavLink href="@($"components/{tag["wa-".Length..]}")">@component</NavLink></li>
                }
            </ul>

            <h4>Layout</h4>
            <ul>
                @foreach (var (route, name) in LayoutLinks)
                {
                    <li><NavLink href="@($"layout/{route}")">@name</NavLink></li>
                }
            </ul>
        </nav>
    </aside>

    <main class="demo-content">
        @Body
    </main>
</div>

@code {
    private IReadOnlyList<(string Tag, string Name)> componentLinks = [];
    private string? theme = "default";
    private bool dark;

    private async Task ApplyThemeAsync()
    {
        // theme stylesheets live next to the main stylesheet; "default" is built into webawesome.css
        var themeHref = theme is null or "default"
            ? null
            : WaOptions.ResolveStylesheetUrl().Replace("/webawesome.css", $"/themes/{theme}.css");
        await JS.InvokeVoidAsync("demoTheme.setTheme", themeHref);
    }

    private async Task ApplyDarkAsync()
    {
        await JS.InvokeVoidAsync("demoTheme.setDark", dark);
    }

    private static readonly (string Route, string Name)[] LayoutLinks =
    [
        ("cluster", "Cluster"),
        ("flank", "Flank"),
        ("frame", "Frame"),
        ("grid", "Grid"),
        ("split", "Split"),
        ("stack", "Stack"),
        ("text", "Text"),
        ("visually-hidden", "Visually Hidden")
    ];

    /// <inheritdoc />
    protected override async Task OnInitializedAsync()
    {
        // the sidebar is driven by the API surface document, so it always matches the bound WA version
        var surface = await SurfaceService.GetSurfaceAsync();
        componentLinks = surface.Components
            .Select(c => (c.Key, Humanize(c.Key)))
            .OrderBy(c => c.Item2)
            .ToList();
    }

    private static string Humanize(string tag)
    {
        var name = tag.StartsWith("wa-") ? tag["wa-".Length..] : tag;
        return string.Join(' ', name.Split('-').Select(part => char.ToUpperInvariant(part[0]) + part[1..]));
    }
}
