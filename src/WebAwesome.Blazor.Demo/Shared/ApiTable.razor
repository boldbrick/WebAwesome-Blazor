@using System.Linq
@using System.Reflection
@inject ApiSurfaceService SurfaceService

@if (component != null)
{
    <section class="api-reference">
        <h2>API Reference</h2>

        @if (component.Attributes is { Count: > 0 })
        {
            <h3>Parameters</h3>
            <table>
                <thead><tr><th>Parameter</th><th>Attribute</th><th>Description</th><th>Type</th><th>Default</th></tr></thead>
                <tbody>
                    @foreach (var attributeEntry in component.Attributes)
                    {
                        <tr>
                            <td><code>@ToPascalCase(attributeEntry.Key)</code></td>
                            <td><code>@attributeEntry.Key</code></td>
                            <td>@attributeEntry.Value.Description</td>
                            <td>
                                <code>@attributeEntry.Value.Type</code>
                                @{
                                    var enumValues = GetEnumValues(attributeEntry.Key, attributeEntry.Value.Type);
                                }
                                @if (enumValues is not null)
                                {
                                    <br />
                                    <code class="api-enum-values">@enumValues</code>
                                }
                            </td>
                            <td><code>@attributeEntry.Value.Default</code></td>
                        </tr>
                    }
                </tbody>
            </table>
            <p class="api-note">Parameter names follow the Blazor convention (PascalCase of the attribute); a few wrappers deviate deliberately — see the wrapper's IntelliSense for the authoritative API.</p>
        }

        @if (component.Events is { Count: > 0 })
        {
            <h3>Events</h3>
            <table>
                <thead><tr><th>Callback</th><th>Event</th><th>Description</th></tr></thead>
                <tbody>
                    @foreach (var evt in component.Events)
                    {
                        <tr>
                            <td><code>@ToEventCallbackName(evt.Key)</code></td>
                            <td><code>@evt.Key</code></td>
                            <td>@evt.Value.Description</td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        @if (component.Slots is { Count: > 0 })
        {
            <h3>Slots</h3>
            <table>
                <thead><tr><th>Slot</th><th>Description</th></tr></thead>
                <tbody>
                    @foreach (var slot in component.Slots)
                    {
                        <tr>
                            <td><code>@slot.Key</code></td>
                            <td>@slot.Value</td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        @if (component.Methods is { Count: > 0 })
        {
            <h3>Methods</h3>
            <table>
                <thead><tr><th>Method</th><th>Description</th></tr></thead>
                <tbody>
                    @foreach (var method in component.Methods)
                    {
                        <tr>
                            <td><code>@(ToPascalCase(method.Key))Async()</code> <span class="api-native">(<code>@method.Value.Signature</code>)</span></td>
                            <td>@method.Value.Description</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>
}

@code {
    /// <summary>
    /// Custom element tag whose API reference is rendered, e.g. "wa-button".
    /// </summary>
    [Parameter, EditorRequired] public string Tag { get; set; } = string.Empty;

    private ComponentSurface? component;

    /// <inheritdoc />
    protected override async Task OnParametersSetAsync()
    {
        var surface = await SurfaceService.GetSurfaceAsync();
        surface.Components.TryGetValue(Tag, out component);
    }

    private static string ToPascalCase(string kebabName)
        => string.Concat(kebabName.Split('-', StringSplitOptions.RemoveEmptyEntries)
            .Select(part => char.ToUpperInvariant(part[0]) + part[1..]));

    private static string ToEventCallbackName(string eventName)
        => "On" + ToPascalCase(eventName.StartsWith("wa-", StringComparison.Ordinal) ? eventName["wa-".Length..] : eventName);

    /// <summary>
    /// Resolves the comma-separated list of allowed values for an enum-typed attribute, formatted using the
    /// wrapper's own <c>ToHtmlValue</c> conversion where available so values match the actual attribute strings.
    /// </summary>
    /// <param name="attributeKey">Kebab-case attribute name, e.g. "direction"</param>
    /// <param name="rawType">The raw type string from the API surface document, e.g. "PlaybackDirection"</param>
    /// <returns>A comma-separated list of allowed values, or null when the type isn't a resolvable enum</returns>
    private string? GetEnumValues(string attributeKey, string? rawType)
    {
        // primitive types and already-expanded TS unions (e.g. "'small' | 'medium'") need no further expansion
        if (string.IsNullOrEmpty(rawType)) return null;
        if (rawType is "string" or "number" or "boolean") return null;
        if (rawType.Contains('|') || rawType.StartsWith('\'')) return null;

        var enumType = ResolveEnumType(component?.ClassName, attributeKey);
        if (enumType is null) return null;

        var converter = FindToHtmlValueMethod(enumType);
        var values = Enum.GetValues(enumType).Cast<object>()
            .Select(value => converter is not null ? (string)converter.Invoke(null, [value])! : value.ToString()!.ToLowerInvariant());
        return string.Join(", ", values);
    }

    /// <summary>
    /// Finds the CLR enum type backing an attribute by reflecting over the wrapper component's public properties.
    /// </summary>
    /// <param name="className">The wrapper's class name, e.g. "WaAnimation"</param>
    /// <param name="attributeKey">Kebab-case attribute name</param>
    /// <returns>The enum type, or null when the wrapper or a matching enum property can't be found</returns>
    private static Type? ResolveEnumType(string? className, string attributeKey)
    {
        if (string.IsNullOrEmpty(className)) return null;

        var wrapperType = typeof(WaButton).Assembly.GetType($"WebAwesome.Blazor.Components.{className}");
        var property = wrapperType?.GetProperty(ToPascalCase(attributeKey), BindingFlags.Public | BindingFlags.Instance);
        var propertyType = property?.PropertyType;
        if (propertyType is null) return null;

        var underlyingType = Nullable.GetUnderlyingType(propertyType) ?? propertyType;
        return underlyingType.IsEnum ? underlyingType : null;
    }

    /// <summary>
    /// Finds the static <c>ToHtmlValue</c> extension method for the given enum type, if one exists.
    /// </summary>
    /// <param name="enumType">The enum type to find a converter for</param>
    /// <returns>The matching method, or null when no dedicated converter exists</returns>
    private static MethodInfo? FindToHtmlValueMethod(Type enumType)
        => enumType.Assembly.GetTypes()
            .Where(type => type.IsAbstract && type.IsSealed)
            .SelectMany(type => type.GetMethods(BindingFlags.Public | BindingFlags.Static))
            .FirstOrDefault(method => method.Name == "ToHtmlValue"
                && method.GetParameters() is [{ } parameter]
                && parameter.ParameterType == enumType);
}
